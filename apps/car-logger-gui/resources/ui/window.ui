<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="GtkApplicationWindow" id="CarLoggerWindow">
    <property name="title">APEX//TRACE — Local Vehicle Intelligence</property>
    <property name="default-width">1180</property>
    <property name="default-height">760</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">horizontal</property>
        <style>
          <class name="app-shell"/>
        </style>
        <child>
          <object class="GtkBox" id="sidebar_container"/>
        </child>
        <child>
          <object class="GtkBox" id="main_surface">
            <property name="orientation">vertical</property>
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>
            <style>
              <class name="main-surface"/>
            </style>

            <child>
              <object class="GtkBox" id="transport_header">
                <property name="orientation">horizontal</property>
                <property name="spacing">14</property>
                <property name="hexpand">true</property>
                <style>
                  <class name="transport-header"/>
                </style>
                <child>
                  <object class="GtkBox" id="brand_row">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">14</property>
                    <property name="hexpand">true</property>
                    <child>
                      <object class="GtkImage">
                        <property name="resource">/com/carlogger/CarLogger/icons/apex-trace.svg</property>
                        <property name="pixel-size">40</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">0</property>
                        <child><object class="GtkLabel"><property name="label">APEX//TRACE</property><property name="halign">start</property><style><class name="brand-name"/></style></object></child>
                        <child><object class="GtkLabel"><property name="label">LOCAL VEHICLE INTELLIGENCE</property><property name="halign">start</property><style><class name="brand-tagline"/></style></object></child>
                      </object>
                    </child>
                    <child><object class="GtkBox"><property name="hexpand">true</property></object></child>
                    <child><object class="GtkLabel"><property name="label">◆ LOCAL ONLY</property><property name="tooltip-text" translatable="yes">Vehicle data stays on this computer</property><style><class name="feature-chip"/><class name="feature-local"/></style></object></child>
                    <child>
                      <object class="GtkButton" id="btn_vehicle_profile">
                        <property name="tooltip-text" translatable="yes">Edit vehicle information</property>
                        <style><class name="vehicle-profile-button"/></style>
                        <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">1</property>
                          <child><object class="GtkLabel" id="lbl_vehicle_name"><property name="label" translatable="yes">Vehicle not configured</property><property name="halign">start</property><style><class name="vehicle-name"/></style></object></child>
                          <child><object class="GtkLabel" id="lbl_vehicle_detail"><property name="label" translatable="yes">Click to configure</property><property name="halign">start</property><property name="ellipsize">end</property><property name="max-width-chars">32</property><style><class name="muted-label"/></style></object></child>
                        </object></child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="GtkStack" id="main_stack">
                <property name="transition-type">slide-left-right</property>
                <property name="hexpand">true</property>
                <property name="vexpand">true</property>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">dashboard</property>
                    <property name="child">
                      <object class="GtkBox" id="dashboard_container">
                        <property name="orientation">vertical</property>
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                        <child>
                          <object class="GtkBox" id="connection_deck">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">14</property>
                            <property name="hexpand">true</property>
                            <style><class name="home-connection-panel"/></style>
                            <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><property name="hexpand">true</property><property name="valign">center</property>
                              <child><object class="GtkLabel"><property name="label" translatable="yes">VEHICLE CONNECTION</property><property name="halign">start</property><style><class name="deck-label"/></style></object></child>
                              <child><object class="GtkBox"><property name="orientation">horizontal</property><property name="spacing">7</property>
                                <child><object class="GtkLabel"><property name="label">●</property><property name="tooltip-text" translatable="yes">Connection status</property><style><class name="connection-indicator"/></style></object></child>
                                <child><object class="GtkLabel" id="lbl_transport_status"><property name="label" translatable="yes">Disconnected</property><property name="halign">start</property><property name="ellipsize">end</property><style><class name="connection-status"/></style></object></child>
                              </object></child>
                            </object></child>
                            <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">4</property>
                              <child><object class="GtkLabel"><property name="label" translatable="yes">INTERFACE</property><property name="halign">start</property><style><class name="control-caption"/></style></object></child>
                              <child><object class="GtkComboBoxText" id="cmb_transport_interface"><property name="width-request">250</property><property name="active">0</property><property name="tooltip-text" translatable="yes">Choose the vehicle interface to use</property><items><item translatable="yes">ASC Coupler - BRZ Stream</item><item translatable="yes">USB OBD-2 - ELM327</item><item translatable="yes">SocketCAN - can0</item></items><style><class name="header-control"/></style></object></child>
                            </object></child>
                            <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">4</property>
                              <child><object class="GtkLabel"><property name="label" translatable="yes">MODE</property><property name="halign">start</property><style><class name="control-caption"/></style></object></child>
                              <child><object class="GtkComboBoxText" id="cmb_transport_mode"><property name="width-request">140</property><property name="active">0</property><property name="tooltip-text" translatable="yes">Choose how vehicle data is read</property><items><item translatable="yes">Stream</item><item translatable="yes">OBD-2</item></items><style><class name="header-control"/></style></object></child>
                            </object></child>
                            <child><object class="GtkButton" id="btn_transport_connect"><property name="label" translatable="yes">Connect</property><property name="valign">end</property><property name="tooltip-text" translatable="yes">Start or stop the vehicle connection</property><style><class name="connect-button"/></style></object></child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">logs</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <property name="spacing">12</property>
                        <child>
                          <object class="GtkLabel" id="lbl_logs_title">
                            <property name="label" translatable="yes">Log Analysis</property>
                            <style>
                              <class name="title-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">health</property>
                    <property name="child">
                      <object class="GtkBox" id="health_container">
                        <property name="orientation">vertical</property>
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">maintenance</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <property name="spacing">12</property>
                        <child>
                          <object class="GtkLabel" id="lbl_maint_title">
                            <property name="label" translatable="yes">Maintenance</property>
                            <style>
                              <class name="title-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">charts</property>
                    <property name="child">
                      <object class="GtkBox" id="log_chart_container">
                        <property name="orientation">vertical</property>
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">can_ids</property>
                    <property name="child">
                      <object class="GtkBox" id="can_id_manager_container">
                        <property name="orientation">vertical</property>
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">settings</property>
                    <property name="child">
                      <object class="GtkBox" id="settings_container">
                        <property name="orientation">vertical</property>
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
