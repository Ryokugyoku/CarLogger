<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="GtkApplicationWindow" id="CarLoggerWindow">
    <property name="title">CarLogger</property>
    <property name="default-width">1180</property>
    <property name="default-height">760</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">horizontal</property>
        <style>
          <class name="app-shell"/>
        </style>
        <child>
          <object class="GtkBox" id="sidebar_container"/>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>
            <style>
              <class name="main-surface"/>
            </style>

            <child>
              <object class="GtkBox" id="transport_header">
                <property name="orientation">horizontal</property>
                <property name="spacing">12</property>
                <property name="hexpand">true</property>
                <style>
                  <class name="transport-header"/>
                </style>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">2</property>
                    <property name="hexpand">true</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Transport</property>
                        <property name="halign">start</property>
                        <style>
                          <class name="section-title"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="lbl_transport_status">
                        <property name="label" translatable="yes">Disconnected</property>
                        <property name="halign">start</property>
                        <style>
                          <class name="muted-label"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkComboBoxText" id="cmb_transport_interface">
                    <property name="width-request">250</property>
                    <property name="active">0</property>
                    <items>
                      <item translatable="yes">ASC Coupler - BRZ Stream</item>
                      <item translatable="yes">USB OBD-2 - ELM327</item>
                      <item translatable="yes">SocketCAN - can0</item>
                    </items>
                    <style>
                      <class name="header-control"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkComboBoxText" id="cmb_transport_mode">
                    <property name="width-request">170</property>
                    <property name="active">0</property>
                    <items>
                      <item translatable="yes">Stream</item>
                      <item translatable="yes">OBD-2</item>
                    </items>
                    <style>
                      <class name="header-control"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="btn_transport_connect">
                    <property name="label" translatable="yes">Connect</property>
                    <style>
                      <class name="connect-button"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="GtkStack" id="main_stack">
                <property name="transition-type">slide-left-right</property>
                <property name="hexpand">true</property>
                <property name="vexpand">true</property>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">dashboard</property>
                    <property name="child">
                      <object class="GtkScrolledWindow">
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                        <property name="hscrollbar-policy">never</property>
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">18</property>
                            <style>
                              <class name="dashboard-root"/>
                            </style>

                            <child>
                              <object class="GtkBox">
                                <property name="orientation">horizontal</property>
                                <property name="spacing">16</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">6</property>
                                    <property name="hexpand">true</property>
                                    <child>
                                      <object class="GtkLabel" id="lbl_dash_title">
                                        <property name="label" translatable="yes">Dashboard</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="title-label"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Realtime engine and CAN state</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="muted-label"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">2</property>
                                    <property name="halign">end</property>
                                    <style>
                                      <class name="status-pill"/>
                                    </style>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">LIVE</property>
                                        <style>
                                          <class name="status-pill-label"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="lbl_last_seen">
                                        <property name="label" translatable="yes">No frames</property>
                                        <style>
                                          <class name="status-pill-subtitle"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="GtkGrid">
                                <property name="column-spacing">12</property>
                                <property name="row-spacing">12</property>
                                <property name="column-homogeneous">true</property>
                                <style>
                                  <class name="metric-grid"/>
                                </style>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">4</property>
                                    <layout>
                                      <property name="column">0</property>
                                      <property name="row">0</property>
                                    </layout>
                                    <style>
                                      <class name="metric-card"/>
                                      <class name="accent-teal"/>
                                    </style>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">RPM</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="metric-label"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="metric_rpm">
                                        <property name="label">--</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="metric-value"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">4</property>
                                    <layout>
                                      <property name="column">1</property>
                                      <property name="row">0</property>
                                    </layout>
                                    <style>
                                      <class name="metric-card"/>
                                      <class name="accent-amber"/>
                                    </style>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Speed</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="metric-label"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="metric_speed">
                                        <property name="label">-- km/h</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="metric-value"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">4</property>
                                    <layout>
                                      <property name="column">2</property>
                                      <property name="row">0</property>
                                    </layout>
                                    <style>
                                      <class name="metric-card"/>
                                      <class name="accent-red"/>
                                    </style>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Coolant</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="metric-label"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="metric_coolant">
                                        <property name="label">-- C</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="metric-value"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">4</property>
                                    <layout>
                                      <property name="column">3</property>
                                      <property name="row">0</property>
                                    </layout>
                                    <style>
                                      <class name="metric-card"/>
                                      <class name="accent-violet"/>
                                    </style>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Throttle</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="metric-label"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="metric_throttle">
                                        <property name="label">-- %</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="metric-value"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="GtkPaned">
                                <property name="orientation">horizontal</property>
                                <property name="wide-handle">true</property>
                                <property name="position">560</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">10</property>
                                    <property name="hexpand">true</property>
                                    <style>
                                      <class name="panel"/>
                                    </style>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Known Signals</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="section-title"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkGrid" id="known_signal_table">
                                        <property name="column-spacing">14</property>
                                        <property name="row-spacing">8</property>
                                        <property name="hexpand">true</property>
                                        <style>
                                          <class name="data-table"/>
                                        </style>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Signal</property>
                                            <property name="halign">start</property>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">0</property>
                                            </layout>
                                            <style><class name="table-head"/></style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Value</property>
                                            <property name="halign">end</property>
                                            <layout>
                                              <property name="column">1</property>
                                              <property name="row">0</property>
                                            </layout>
                                            <style><class name="table-head"/></style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Source</property>
                                            <property name="halign">start</property>
                                            <layout>
                                              <property name="column">2</property>
                                              <property name="row">0</property>
                                            </layout>
                                            <style><class name="table-head"/></style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel" id="known_signal_empty">
                                            <property name="label" translatable="yes">Waiting for decoded CAN/PID values</property>
                                            <property name="halign">start</property>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">1</property>
                                              <property name="column-span">3</property>
                                            </layout>
                                            <style><class name="table-empty"/></style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">10</property>
                                    <property name="hexpand">true</property>
                                    <style>
                                      <class name="panel"/>
                                    </style>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Unknown CAN IDs</property>
                                        <property name="halign">start</property>
                                        <style>
                                          <class name="section-title"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkGrid" id="unknown_can_table">
                                        <property name="column-spacing">14</property>
                                        <property name="row-spacing">8</property>
                                        <property name="hexpand">true</property>
                                        <style>
                                          <class name="data-table"/>
                                        </style>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">CAN ID</property>
                                            <property name="halign">start</property>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">0</property>
                                            </layout>
                                            <style><class name="table-head"/></style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Payload</property>
                                            <property name="halign">start</property>
                                            <layout>
                                              <property name="column">1</property>
                                              <property name="row">0</property>
                                            </layout>
                                            <style><class name="table-head"/></style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Count</property>
                                            <property name="halign">end</property>
                                            <layout>
                                              <property name="column">2</property>
                                              <property name="row">0</property>
                                            </layout>
                                            <style><class name="table-head"/></style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel" id="unknown_can_empty">
                                            <property name="label" translatable="yes">No unknown frames</property>
                                            <property name="halign">start</property>
                                            <layout>
                                              <property name="column">0</property>
                                              <property name="row">1</property>
                                              <property name="column-span">3</property>
                                            </layout>
                                            <style><class name="table-empty"/></style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">10</property>
                                <style>
                                  <class name="panel"/>
                                </style>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label" translatable="yes">Signal Definition Table</property>
                                    <property name="halign">start</property>
                                    <style>
                                      <class name="section-title"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkGrid" id="signal_definition_table">
                                    <property name="column-spacing">14</property>
                                    <property name="row-spacing">8</property>
                                    <style>
                                      <class name="data-table"/>
                                    </style>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Type</property>
                                        <property name="halign">start</property>
                                        <layout><property name="column">0</property><property name="row">0</property></layout>
                                        <style><class name="table-head"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">ID</property>
                                        <property name="halign">start</property>
                                        <layout><property name="column">1</property><property name="row">0</property></layout>
                                        <style><class name="table-head"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Formula</property>
                                        <property name="halign">start</property>
                                        <layout><property name="column">2</property><property name="row">0</property></layout>
                                        <style><class name="table-head"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">CAN ID</property>
                                        <property name="halign">start</property>
                                        <layout><property name="column">0</property><property name="row">1</property></layout>
                                        <style><class name="mono-cell"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">0x0C</property>
                                        <property name="halign">start</property>
                                        <layout><property name="column">1</property><property name="row">1</property></layout>
                                        <style><class name="mono-cell"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">((A*256)+B)/4</property>
                                        <property name="halign">start</property>
                                        <layout><property name="column">2</property><property name="row">1</property></layout>
                                        <style><class name="mono-cell"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">PID</property>
                                        <property name="halign">start</property>
                                        <layout><property name="column">0</property><property name="row">2</property></layout>
                                        <style><class name="mono-cell"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">0x0C</property>
                                        <property name="halign">start</property>
                                        <layout><property name="column">1</property><property name="row">2</property></layout>
                                        <style><class name="mono-cell"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">((A*256)+B)/4</property>
                                        <property name="halign">start</property>
                                        <layout><property name="column">2</property><property name="row">2</property></layout>
                                        <style><class name="mono-cell"/></style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">logs</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <property name="spacing">12</property>
                        <child>
                          <object class="GtkLabel" id="lbl_logs_title">
                            <property name="label" translatable="yes">Log Analysis</property>
                            <style>
                              <class name="title-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">maintenance</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <property name="spacing">12</property>
                        <child>
                          <object class="GtkLabel" id="lbl_maint_title">
                            <property name="label" translatable="yes">Maintenance</property>
                            <style>
                              <class name="title-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">can_ids</property>
                    <property name="child">
                      <object class="GtkBox" id="can_id_manager_container">
                        <property name="orientation">vertical</property>
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="GtkStackPage">
                    <property name="name">settings</property>
                    <property name="child">
                      <object class="GtkBox" id="settings_container">
                        <property name="orientation">vertical</property>
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
