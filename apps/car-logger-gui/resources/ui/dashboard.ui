<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="GtkScrolledWindow" id="dashboard_view">
    <property name="hexpand">true</property>
    <property name="vexpand">true</property>
    <property name="hscrollbar-policy">never</property>
    <child>
      <object class="GtkStack" id="dashboard_mode_stack">
        <property name="transition-type">crossfade</property>
        <property name="transition-duration">250</property>
        <property name="hexpand">true</property>
        <property name="vexpand">true</property>
        <child>
          <object class="GtkStackPage">
            <property name="name">offline</property>
            <property name="child">
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">14</property>
                <style><class name="dashboard-root"/><class name="offline-dashboard"/></style>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">7</property>
                    <style><class name="offline-hero"/></style>
                    <child><object class="GtkLabel"><property name="label">APEX//TRACE · OFFLINE</property><property name="halign">start</property><style><class name="hero-eyebrow"/></style></object></child>
                    <child><object class="GtkLabel" id="lbl_offline_title"><property name="label" translatable="yes">Vehicle overview</property><property name="halign">start</property><style><class name="hero-title"/></style></object></child>
                    <child><object class="GtkLabel" id="lbl_offline_subtitle"><property name="label" translatable="yes">Connect to the vehicle to show realtime telemetry.</property><property name="halign">start</property><property name="wrap">true</property><style><class name="hero-subtitle"/></style></object></child>
                  </object>
                </child>
                <child>
                  <object class="GtkGrid">
                    <property name="column-spacing">14</property><property name="row-spacing">14</property><property name="column-homogeneous">true</property>
                    <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">8</property><layout><property name="column">0</property><property name="row">0</property></layout><style><class name="offline-card"/><class name="offline-health-card"/></style>
                      <child><object class="GtkLabel"><property name="label" translatable="yes">LATEST HEALTH SCORE</property><property name="halign">start</property><style><class name="dashboard-section-title"/></style></object></child>
                      <child><object class="GtkLabel" id="offline_health_score"><property name="label">—</property><property name="halign">start</property><style><class name="offline-score"/></style></object></child>
                      <child><object class="GtkLabel" id="offline_health_state"><property name="label" translatable="yes">Loading vehicle history…</property><property name="halign">start</property><style><class name="offline-card-primary"/></style></object></child>
                      <child><object class="GtkLabel" id="offline_health_meta"><property name="label">—</property><property name="halign">start</property><property name="wrap">true</property><style><class name="muted-label"/></style></object></child>
                    </object></child>
                    <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">8</property><layout><property name="column">1</property><property name="row">0</property></layout><style><class name="offline-card"/><class name="offline-diagnostic-card"/></style>
                      <child><object class="GtkLabel"><property name="label" translatable="yes">DIAGNOSTICS</property><property name="halign">start</property><style><class name="dashboard-section-title"/></style></object></child>
                      <child><object class="GtkLabel" id="offline_diagnostic_state"><property name="label">—</property><property name="halign">start</property><style><class name="offline-card-primary"/></style></object></child>
                      <child><object class="GtkLabel" id="offline_diagnostic_meta"><property name="label">—</property><property name="halign">start</property><property name="wrap">true</property><style><class name="muted-label"/></style></object></child>
                      <child><object class="GtkLabel"><property name="label" translatable="yes">No DTCs does not guarantee that the vehicle has no fault.</property><property name="halign">start</property><property name="wrap">true</property><style><class name="offline-note"/></style></object></child>
                    </object></child>
                    <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">10</property><layout><property name="column">0</property><property name="row">1</property><property name="column-span">2</property></layout><style><class name="offline-card"/></style>
                      <child><object class="GtkLabel"><property name="label" translatable="yes">CONDITION BY SYSTEM</property><property name="halign">start</property><style><class name="dashboard-section-title"/></style></object></child>
                      <child><object class="GtkGrid"><property name="column-homogeneous">true</property><property name="column-spacing">10</property>
                        <child><object class="GtkBox"><property name="orientation">vertical</property><layout><property name="column">0</property><property name="row">0</property></layout><child><object class="GtkLabel"><property name="label" translatable="yes">Thermal</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="offline_domain_thermal"><property name="label">—</property><style><class name="offline-domain-score"/></style></object></child></object></child>
                        <child><object class="GtkBox"><property name="orientation">vertical</property><layout><property name="column">1</property><property name="row">0</property></layout><child><object class="GtkLabel"><property name="label" translatable="yes">Electrical</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="offline_domain_electrical"><property name="label">—</property><style><class name="offline-domain-score"/></style></object></child></object></child>
                        <child><object class="GtkBox"><property name="orientation">vertical</property><layout><property name="column">2</property><property name="row">0</property></layout><child><object class="GtkLabel"><property name="label" translatable="yes">Air / fuel</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="offline_domain_air_fuel"><property name="label">—</property><style><class name="offline-domain-score"/></style></object></child></object></child>
                        <child><object class="GtkBox"><property name="orientation">vertical</property><layout><property name="column">3</property><property name="row">0</property></layout><child><object class="GtkLabel"><property name="label" translatable="yes">Running stability</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="offline_domain_stability"><property name="label">—</property><style><class name="offline-domain-score"/></style></object></child></object></child>
                      </object></child>
                    </object></child>
                    <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">8</property><layout><property name="column">0</property><property name="row">2</property></layout><style><class name="offline-card"/><class name="offline-learning-card"/></style>
                      <child><object class="GtkLabel"><property name="label" translatable="yes">LEARNING &amp; DATA</property><property name="halign">start</property><style><class name="dashboard-section-title"/></style></object></child>
                      <child><object class="GtkLabel" id="offline_learning"><property name="label">—</property><property name="halign">start</property><property name="wrap">true</property><style><class name="offline-card-primary"/></style></object></child>
                    </object></child>
                    <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">8</property><layout><property name="column">1</property><property name="row">2</property></layout><style><class name="offline-card"/><class name="offline-connect-card"/></style>
                      <child><object class="GtkLabel"><property name="label" translatable="yes">READY TO CONNECT</property><property name="halign">start</property><style><class name="dashboard-section-title"/></style></object></child>
                      <child><object class="GtkLabel"><property name="label" translatable="yes">Select an interface in the connection deck above, then press Connect.</property><property name="halign">start</property><property name="wrap">true</property><style><class name="offline-card-primary"/></style></object></child>
                    </object></child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>
        <child>
          <object class="GtkStackPage">
            <property name="name">live</property>
            <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">14</property>
        <style>
          <class name="dashboard-root"/>
        </style>
        <child>
          <object class="GtkOverlay">
            <property name="height-request">176</property>
            <style>
              <class name="dashboard-hero"/>
            </style>
            <child>
              <object class="GtkPicture">
                <property name="file">resource:///com/carlogger/CarLogger/icons/dashboard-vehicle-hero.png</property>
                <property name="content-fit">cover</property>
                <property name="can-shrink">true</property>
                <property name="hexpand">true</property>
                <property name="vexpand">true</property>
              </object>
            </child>
            <child type="overlay">
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">8</property>
                <property name="halign">start</property>
                <property name="valign">center</property>
                <property name="margin-start">24</property>
                <property name="margin-end">180</property>
                <style>
                  <class name="hero-copy"/>
                </style>
                <child>
                  <object class="GtkLabel">
                    <property name="label">APEX//TRACE</property>
                    <property name="halign">start</property>
                    <style>
                      <class name="hero-eyebrow"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="lbl_dash_title">
                    <property name="label" translatable="yes">Dashboard</property>
                    <property name="halign">start</property>
                    <style>
                      <class name="hero-title"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="lbl_dashboard_subtitle">
                    <property name="label" translatable="yes">Realtime vehicle telemetry</property>
                    <property name="halign">start</property>
                    <property name="wrap">true</property>
                    <style>
                      <class name="hero-subtitle"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
            <child type="overlay">
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">2</property>
                <property name="halign">end</property>
                <property name="valign">start</property>
                <property name="margin-top">20</property>
                <property name="margin-end">20</property>
                <property name="tooltip-text" translatable="yes">Connection activity and time of the most recent frame</property>
                <style>
                  <class name="status-pill"/>
                  <class name="live-glow"/>
                </style>
                <child>
                  <object class="GtkLabel" id="lbl_dashboard_live">
                    <property name="label" translatable="yes">● LIVE</property>
                    <style>
                      <class name="status-pill-label"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="lbl_last_seen">
                    <property name="label" translatable="yes">No frames</property>
                    <style>
                      <class name="status-pill-subtitle"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkGrid">
            <property name="column-spacing">14</property>
            <property name="row-spacing">14</property>
            <property name="column-homogeneous">true</property>
            <property name="hexpand">true</property>
            <child>
              <object class="GtkBox" id="engine_card">
                <property name="orientation">vertical</property>
                <property name="spacing">14</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
                <style>
                  <class name="panel"/>
                  <class name="dashboard-card"/>
                  <class name="engine-card"/>
                  <class name="rpm-idle"/>
                </style>
                <child>
                  <object class="GtkLabel" id="lbl_dashboard_engine">
                    <property name="label" translatable="yes">ENGINE</property>
                    <property name="halign">start</property>
                    <style>
                      <class name="dashboard-section-title"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkGrid">
                    <property name="column-spacing">18</property>
                    <property name="row-spacing">16</property>
                    <property name="column-homogeneous">true</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">3</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">0</property>
                        </layout>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">RPM</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="metric-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="metric_rpm">
                            <property name="label">--</property>
                            <property name="halign">start</property>
                            <property name="selectable">true</property>
                            <style>
                              <class name="dashboard-metric-value"/>
                              <class name="primary-metric-value"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">3</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">0</property>
                        </layout>
                        <child>
                          <object class="GtkLabel" id="lbl_dashboard_speed">
                            <property name="label" translatable="yes">Vehicle speed</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="metric-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="metric_speed">
                            <property name="label">--</property>
                            <property name="halign">start</property>
                            <property name="selectable">true</property>
                            <style>
                              <class name="dashboard-metric-value"/>
                              <class name="primary-metric-value"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">3</property>
                        <layout>
                          <property name="column">2</property>
                          <property name="row">0</property>
                        </layout>
                        <child>
                          <object class="GtkLabel" id="lbl_dashboard_intake_pressure">
                            <property name="label" translatable="yes">Intake pressure</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="metric-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="metric_intake_pressure">
                            <property name="label">--</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="dashboard-metric-value"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">3</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">1</property>
                        </layout>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">MAF</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="metric-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="metric_maf">
                            <property name="label">--</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="dashboard-metric-value"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">3</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">1</property>
                        </layout>
                        <child>
                          <object class="GtkLabel" id="lbl_dashboard_timing">
                            <property name="label" translatable="yes">Timing advance</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="metric-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="metric_timing_advance">
                            <property name="label">--</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="dashboard-metric-value"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">3</property>
                        <layout>
                          <property name="column">2</property>
                          <property name="row">1</property>
                        </layout>
                        <child>
                          <object class="GtkLabel" id="lbl_dashboard_voltage">
                            <property name="label" translatable="yes">Voltage</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="metric-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="metric_voltage">
                            <property name="label">--</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="dashboard-metric-value"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">0</property>
                  <property name="row-span">2</property>
                </layout>
                <style>
                  <class name="panel"/>
                  <class name="dashboard-card"/>
                  <class name="ratio-card"/>
                </style>
                <child>
                  <object class="GtkLabel" id="lbl_dashboard_ratios">
                    <property name="label" translatable="yes">LIVE RATIOS</property>
                    <property name="halign">start</property>
                    <style>
                      <class name="dashboard-section-title"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="ratio_chart_container">
                    <property name="orientation">vertical</property>
                    <property name="spacing">12</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">14</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">1</property>
                </layout>
                <style>
                  <class name="panel"/>
                  <class name="dashboard-card"/>
                  <class name="temperature-card"/>
                </style>
                <child>
                  <object class="GtkLabel" id="lbl_dashboard_temperatures">
                    <property name="label" translatable="yes">TEMPERATURES</property>
                    <property name="halign">start</property>
                    <style>
                      <class name="dashboard-section-title"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkGrid">
                    <property name="column-spacing">18</property>
                    <property name="row-spacing">16</property>
                    <property name="column-homogeneous">true</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">3</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">0</property>
                        </layout>
                        <child>
                          <object class="GtkLabel" id="lbl_dashboard_coolant">
                            <property name="label" translatable="yes">Coolant</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="metric-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="metric_coolant">
                            <property name="label">--</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="dashboard-metric-value"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">3</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">0</property>
                        </layout>
                        <child>
                          <object class="GtkLabel" id="lbl_dashboard_intake_air">
                            <property name="label" translatable="yes">Intake air</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="metric-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="metric_intake_temp">
                            <property name="label">--</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="dashboard-metric-value"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">3</property>
                        <layout>
                          <property name="column">2</property>
                          <property name="row">0</property>
                        </layout>
                        <child>
                          <object class="GtkLabel" id="lbl_dashboard_ambient">
                            <property name="label" translatable="yes">Ambient</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="metric-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="metric_ambient_temp">
                            <property name="label">--</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="dashboard-metric-value"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">3</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">1</property>
                        </layout>
                        <child>
                          <object class="GtkLabel" id="lbl_dashboard_oil">
                            <property name="label" translatable="yes">Engine oil</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="metric-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="metric_oil_temp">
                            <property name="label">--</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="dashboard-metric-value"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">3</property>
                        <layout>
                          <property name="column">1</property>
                          <property name="row">1</property>
                        </layout>
                        <child>
                          <object class="GtkLabel" id="lbl_dashboard_catalyst">
                            <property name="label" translatable="yes">Catalyst</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="metric-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="metric_catalyst_temp">
                            <property name="label">--</property>
                            <property name="halign">start</property>
                            <style>
                              <class name="dashboard-metric-value"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
            <style>
              <class name="panel"/>
              <class name="dashboard-card"/>
              <class name="trip-card"/>
            </style>
            <child>
              <object class="GtkLabel" id="lbl_dashboard_trip">
                <property name="label" translatable="yes">TRIP &amp; DIAGNOSTICS</property>
                <property name="halign">start</property>
                <style>
                  <class name="dashboard-section-title"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkGrid">
                <property name="column-spacing">18</property>
                <property name="column-homogeneous">true</property>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
