<?xml version="1.0" encoding="UTF-8"?>
<interface>
<object class="GtkScrolledWindow" id="dashboard_view"><property name="hexpand">true</property><property name="vexpand">true</property><property name="hscrollbar-policy">never</property><child>
<object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">18</property><style><class name="dashboard-root"/></style>
<child><object class="GtkBox"><property name="orientation">horizontal</property><property name="spacing">16</property>
<child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">5</property><property name="hexpand">true</property><child><object class="GtkLabel" id="lbl_dash_title"><property name="label" translatable="yes">Dashboard</property><property name="halign">start</property><style><class name="title-label"/></style></object></child><child><object class="GtkLabel" id="lbl_dashboard_subtitle"><property name="label" translatable="yes">Realtime vehicle telemetry</property><property name="halign">start</property><style><class name="muted-label"/></style></object></child></object></child>
<child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">2</property><property name="halign">end</property><style><class name="status-pill"/><class name="live-glow"/></style><child><object class="GtkLabel" id="lbl_dashboard_live"><property name="label" translatable="yes">● LIVE</property><style><class name="status-pill-label"/></style></object></child><child><object class="GtkLabel" id="lbl_last_seen"><property name="label" translatable="yes">No frames</property><style><class name="status-pill-subtitle"/></style></object></child></object></child>
</object></child>
<child><object class="GtkGrid"><property name="column-spacing">14</property><property name="row-spacing">14</property><property name="column-homogeneous">true</property>
<child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">14</property><layout><property name="column">0</property><property name="row">0</property></layout><style><class name="panel"/><class name="dashboard-card"/><class name="engine-card"/></style><child><object class="GtkLabel" id="lbl_dashboard_engine"><property name="label" translatable="yes">ENGINE</property><property name="halign">start</property><style><class name="dashboard-section-title"/></style></object></child><child><object class="GtkGrid"><property name="column-spacing">18</property><property name="row-spacing">16</property><property name="column-homogeneous">true</property>                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">0</property><property name="row">0</property></layout><child><object class="GtkLabel"><property name="label" translatable="yes">RPM</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_rpm"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">1</property><property name="row">0</property></layout><child><object class="GtkLabel" id="lbl_dashboard_speed"><property name="label" translatable="yes">Vehicle speed</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_speed"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">2</property><property name="row">0</property></layout><child><object class="GtkLabel" id="lbl_dashboard_intake_pressure"><property name="label" translatable="yes">Intake pressure</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_intake_pressure"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">0</property><property name="row">1</property></layout><child><object class="GtkLabel"><property name="label" translatable="yes">MAF</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_maf"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">1</property><property name="row">1</property></layout><child><object class="GtkLabel" id="lbl_dashboard_timing"><property name="label" translatable="yes">Timing advance</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_timing_advance"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">2</property><property name="row">1</property></layout><child><object class="GtkLabel" id="lbl_dashboard_voltage"><property name="label" translatable="yes">Voltage</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_voltage"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child></object></child></object></child>
<child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">12</property><layout><property name="column">1</property><property name="row">0</property><property name="row-span">2</property></layout><style><class name="panel"/><class name="dashboard-card"/><class name="ratio-card"/></style><child><object class="GtkLabel" id="lbl_dashboard_ratios"><property name="label" translatable="yes">LIVE RATIOS</property><property name="halign">start</property><style><class name="dashboard-section-title"/></style></object></child><child><object class="GtkBox" id="ratio_chart_container"><property name="orientation">vertical</property><property name="spacing">12</property></object></child></object></child>
<child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">14</property><layout><property name="column">0</property><property name="row">1</property></layout><style><class name="panel"/><class name="dashboard-card"/><class name="temperature-card"/></style><child><object class="GtkLabel" id="lbl_dashboard_temperatures"><property name="label" translatable="yes">TEMPERATURES</property><property name="halign">start</property><style><class name="dashboard-section-title"/></style></object></child><child><object class="GtkGrid"><property name="column-spacing">18</property><property name="row-spacing">16</property><property name="column-homogeneous">true</property>                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">0</property><property name="row">0</property></layout><child><object class="GtkLabel" id="lbl_dashboard_coolant"><property name="label" translatable="yes">Coolant</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_coolant"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">1</property><property name="row">0</property></layout><child><object class="GtkLabel" id="lbl_dashboard_intake_air"><property name="label" translatable="yes">Intake air</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_intake_temp"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">2</property><property name="row">0</property></layout><child><object class="GtkLabel" id="lbl_dashboard_ambient"><property name="label" translatable="yes">Ambient</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_ambient_temp"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">0</property><property name="row">1</property></layout><child><object class="GtkLabel" id="lbl_dashboard_oil"><property name="label" translatable="yes">Engine oil</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_oil_temp"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">1</property><property name="row">1</property></layout><child><object class="GtkLabel" id="lbl_dashboard_catalyst"><property name="label" translatable="yes">Catalyst</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_catalyst_temp"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child></object></child></object></child>
</object></child>
<child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">12</property><style><class name="panel"/><class name="dashboard-card"/></style><child><object class="GtkLabel" id="lbl_dashboard_trip"><property name="label" translatable="yes">TRIP &amp; DIAGNOSTICS</property><property name="halign">start</property><style><class name="dashboard-section-title"/></style></object></child><child><object class="GtkGrid"><property name="column-spacing">18</property><property name="column-homogeneous">true</property>                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">0</property><property name="row">0</property></layout><child><object class="GtkLabel" id="lbl_dashboard_mil_distance"><property name="label" translatable="yes">MIL distance</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_distance_mil"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">1</property><property name="row">0</property></layout><child><object class="GtkLabel" id="lbl_dashboard_dtc_distance"><property name="label" translatable="yes">DTC cleared distance</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_distance_dtc"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">3</property><layout><property name="column">2</property><property name="row">0</property></layout><child><object class="GtkLabel" id="lbl_dashboard_run_time"><property name="label" translatable="yes">Engine run time</property><property name="halign">start</property><style><class name="metric-label"/></style></object></child><child><object class="GtkLabel" id="metric_run_time"><property name="label">--</property><property name="halign">start</property><style><class name="dashboard-metric-value"/></style></object></child></object></child></object></child></object></child>
<child><object class="GtkPaned"><property name="orientation">horizontal</property><property name="wide-handle">true</property><property name="position">560</property>            <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">10</property><property name="hexpand">true</property><style><class name="panel"/><class name="dashboard-card"/></style><child><object class="GtkLabel" id="lbl_dashboard_known"><property name="label" translatable="yes">Known Signals</property><property name="halign">start</property><style><class name="dashboard-section-title"/></style></object></child><child><object class="GtkGrid" id="known_signal_table"><property name="column-spacing">14</property><property name="row-spacing">8</property><property name="hexpand">true</property><style><class name="data-table"/></style><child><object class="GtkLabel" id="lbl_dashboard_signal"><property name="label" translatable="yes">Signal</property><property name="halign">start</property><layout><property name="column">0</property><property name="row">0</property></layout><style><class name="table-head"/></style></object></child><child><object class="GtkLabel" id="lbl_dashboard_value"><property name="label" translatable="yes">Value</property><property name="halign">end</property><layout><property name="column">1</property><property name="row">0</property></layout><style><class name="table-head"/></style></object></child><child><object class="GtkLabel" id="lbl_dashboard_source"><property name="label" translatable="yes">Source</property><property name="halign">start</property><layout><property name="column">2</property><property name="row">0</property></layout><style><class name="table-head"/></style></object></child></object></child></object></child>            <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">10</property><property name="hexpand">true</property><style><class name="panel"/><class name="dashboard-card"/></style><child><object class="GtkLabel" id="lbl_dashboard_unknown"><property name="label" translatable="yes">Unknown CAN IDs</property><property name="halign">start</property><style><class name="dashboard-section-title"/></style></object></child><child><object class="GtkGrid" id="unknown_can_table"><property name="column-spacing">14</property><property name="row-spacing">8</property><property name="hexpand">true</property><style><class name="data-table"/></style><child><object class="GtkLabel" id="lbl_dashboard_can_id"><property name="label" translatable="yes">CAN ID</property><property name="halign">start</property><layout><property name="column">0</property><property name="row">0</property></layout><style><class name="table-head"/></style></object></child><child><object class="GtkLabel" id="lbl_dashboard_payload"><property name="label" translatable="yes">Payload</property><property name="halign">end</property><layout><property name="column">1</property><property name="row">0</property></layout><style><class name="table-head"/></style></object></child><child><object class="GtkLabel" id="lbl_dashboard_count"><property name="label" translatable="yes">Count</property><property name="halign">start</property><layout><property name="column">2</property><property name="row">0</property></layout><style><class name="table-head"/></style></object></child></object></child></object></child></object></child>
</object></child></object>
</interface>
